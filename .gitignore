# ──────────────────────────────────────────────
# .gitignore for React Native + Expo Project
# IndoorNavigationRN — Airport Indoor Navigation
# ──────────────────────────────────────────────

# ── Node ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ── Expo ──────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/

# ── Native builds ─────────────────────────────
# Android
android/
!android/gradle.properties

# iOS
ios/
!ios/Podfile

# ── Build outputs ─────────────────────────────
build/
*.apk
*.ipa
*.aab
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ── Metro bundler cache ───────────────────────
.metro-health-check*
.metro/

# ── Environment variables ─────────────────────
# NEVER commit .env files — they contain secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ── OS generated files ────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ── IDE / Editor ──────────────────────────────
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iws
*.iml
*.ipr

# Vim
*.swp
*.swo
Session.vim
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# Emacs
*~
\#*\#
.\#*

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/
jest-results/
test-results/

# ── TypeScript ────────────────────────────────
*.tsbuildinfo

# ── Logs ──────────────────────────────────────
logs/
*.log
lerna-debug.log*

# ── Temporary files ───────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.cache

# ── EAS Build (Expo Application Services) ─────
.easignore

# ── Watchman ──────────────────────────────────
.watchman-cache/

# ── React Native specific ─────────────────────
# Flipper
ios/Pods/
android/.gradle/
android/app/build/
android/build/

# Hermes
android/app/src/main/assets/index.android.bundle
android/app/src/main/assets/index.android.map

# ── Certificates & Secrets ────────────────────
# These should NEVER be committed
*.pem
*.cert
*.crt
google-services.json
GoogleService-Info.plist