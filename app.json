// 
{
  "expo": {
    "name": "IndoorNavigationRN",
    "slug": "indoor-navigation-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1A2544",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#1A2544",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "platforms": ["ios", "android", "web"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.indoornavigationrn.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A2544"
      },
      "package": "com.indoornavigationrn.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "themeColor": "#1A2544",
      "backgroundColor": "#1A2544"
    },
    "plugins": []
  }
}